# .env for babsapp

# Server port
PORT=3010

# Default HTML file to serve
DEFAULT_HTML=all.html

# Public directory
PUBLIC_DIR=.

# Database settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=

# LaTeX file and PDF output
TEX_FILE=note.tex
PDF_FILE=note.pdf

# Optional: Editor interface
EDITOR_HTML=editor.html

# Logging
LOG_FILE=out.log


